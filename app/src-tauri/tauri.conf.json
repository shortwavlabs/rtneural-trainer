{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RTNeural Trainer",
  "version": "0.1.0",
  "identifier": "labs.shortwav.rtneural-trainer",
  "build": {
    "beforeDevCommand": "pnpm dev:tauri-assets",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build:tauri-assets",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RTNeural Trainer",
        "width": 1920,
        "height": 1200,
        "minWidth": 960,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/projects/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/rttrainer",
      "binaries/rtneural-validator"
    ]
  }
}
