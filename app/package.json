{
  "name": "rtneural-trainer-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:tauri-assets": "pnpm package:sidecars:dev && pnpm dev",
    "build": "tsc && vite build",
    "build:tauri-assets": "pnpm package:sidecars && pnpm build",
    "build:validators": "python3 ../scripts/build_rtneural_validators.py",
    "package:sidecars": "python3 ../scripts/package_tauri_sidecars.py",
    "package:sidecars:dev": "python3 ../scripts/package_tauri_sidecars.py --dev-shims",
    "preview": "vite preview --host 127.0.0.1",
    "smoke:packaged-app": "python3 ../scripts/smoke_packaged_app.py",
    "smoke:release-package": "python3 ../scripts/smoke_release_package.py",
    "smoke:tauri-ui": "vitest run src/test/tauri-ui-smoke.test.tsx",
    "smoke:tauri-workflow": "python3 ../scripts/smoke_tauri_workflow.py",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
